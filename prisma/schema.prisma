generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum SupportStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum RecurrenceFrequency {
  WEEKLY
  MONTHLY
  YEARLY
}

enum CategorySource {
  SEED
  CUSTOM
}

model Planning {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  active          Boolean
  currency        String
  dateOfCreation  DateTime @map("date_of_creation")
  description     String
  isDefault       Boolean  @map("default")
  currentBalance  Float    @map("current_balance")
  expectedBalance Float    @map("expected_balance")
  userId          String   @map("user_id")

  @@map("plannings")
}

model Period {
  id                             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                         String   @map("user_id")
  planningId                     String   @map("planning_id") @db.ObjectId
  periodBalance                  Float    @map("period_balance")
  periodBalancePaidOnly          Float    @map("period_balance_paid_only")
  expectedAllTimeBalance         Float    @map("expected_all_time_balance")
  expectedAllTimeBalancePaidOnly Float    @map("expected_all_time_balance_paid_only")
  periodEnd                      DateTime @map("period_end")
  periodStart                    DateTime @map("period_start")

  transactions Transaction[]

  @@map("periods")
}

model Transaction {
  id                String          @id @default(auto()) @map("_id") @db.ObjectId
  periodId          String          @map("period_id") @db.ObjectId
  planningId        String          @map("planning_id") @db.ObjectId
  categoryId        String          @map("category_id") @db.ObjectId
  userId            String          @map("user_id")
  amount            Float
  date              DateTime        @db.Date
  dateCreated       DateTime        @map("date_created") @db.Date
  description       String
  isPaid            Boolean         @map("is_paid")
  type              TransactionType
  recurringConfigId String?         @map("recurring_config_id") @db.ObjectId

  category        Category         @relation(fields: [categoryId], references: [id])
  period          Period           @relation(fields: [periodId], references: [id])
  recurringConfig RecurringConfig? @relation(fields: [recurringConfigId], references: [id])

  @@map("transactions")
}

model RecurringConfig {
  id                String              @id @default(auto()) @map("_id") @db.ObjectId
  userId            String              @map("user_id")
  planningId        String              @map("planning_id") @db.ObjectId
  categoryId        String              @map("category_id") @db.ObjectId
  amount            Float
  description       String
  type              TransactionType
  frequency         RecurrenceFrequency
  startDate         DateTime            @map("start_date") @db.Date
  endDate           DateTime?           @map("end_date") @db.Date
  recurringDay      Int                 @map("recurring_day")
  lastGeneratedDate DateTime?           @map("last_generated_date") @db.Date
  active            Boolean
  dateCreated       DateTime            @map("date_created") @db.Date

  transactions Transaction[]

  @@map("recurring_configs")
}

model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  active         Boolean
  dateOfCreation DateTime @map("date_of_creation")
  email          String   @unique
  name           String
  password       String?
  language       String?
  googleId       String?
  appleId        String?
  locale         String?
  picture        String?

  categories Category[]

  @@map("users")
}

model Category {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  userId           String?         @map("user_id") @db.ObjectId
  parentCategoryId String?         @map("parent_category_id") @db.ObjectId
  source           CategorySource  @default(SEED)
  active           Boolean
  description      String
  customLabel      String?         @map("custom_label")
  icon             String
  color            String
  type             TransactionType
  User             User?           @relation(fields: [userId], references: [id])
  Transaction      Transaction[]
  parent           Category?       @relation("CategoryChildren", fields: [parentCategoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children         Category[]      @relation("CategoryChildren")

  @@index([userId, parentCategoryId])
  @@index([userId, active])
  @@map("categories")
}

model SupportRequests {
  id      String        @id @default(auto()) @map("_id") @db.ObjectId
  email   String
  name    String
  origin  String
  subject String
  message String
  date    DateTime      @db.Date
  status  SupportStatus

  @@map("support_requests")
}
